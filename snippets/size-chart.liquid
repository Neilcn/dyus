<style>
  .size-toggle {
    margin: 10px 0;
    cursor: pointer;
  }
  .toggle-btn {
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .toggle-btn:hover {
    opacity: 0.8;
  }
  .toggle-btn.active {
    font-weight: bold;
    opacity: 1;
    text-decoration: underline;
  }
  .size-chart-table thead tr,
  .size-chart-table tbody td {
    padding-left: 0;
    text-align: left;
    min-width: 55px;
  }
  .size-chart-table tbody td {
    border-top: 1px solid #dadad6;
  }
  .size-chart-table table {
    width: 100%;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sizeCharts = document.querySelectorAll('.size-chart-table');

    // Set default active
    const defaultUnit = 'inch';

    sizeCharts.forEach((chart) => {
      const toggles = chart.querySelectorAll('.toggle-btn');
      const tables = chart.querySelectorAll('table');

      // Initialize state explicitly
      toggles.forEach((b) => {
        if (b.dataset.unit === defaultUnit) b.classList.add('active');
        else b.classList.remove('active');
      });
      tables.forEach((t) => {
        if (t.classList.contains(defaultUnit)) t.style.display = 'table';
        else t.style.display = 'none';
      });

      toggles.forEach((btn) => {
        btn.addEventListener('click', function () {
          const unit = this.dataset.unit;

          // Toggle buttons
          toggles.forEach((b) => b.classList.remove('active'));
          this.classList.add('active');

          // Toggle tables
          tables.forEach((t) => {
            if (t.classList.contains(unit)) {
              t.style.display = 'table';
            } else {
              t.style.display = 'none';
            }
          });
        });
      });
    });
  });
</script>
